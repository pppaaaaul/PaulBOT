{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run blackjack data access tests",
            "type": "debugpy",
            "request": "launch",
            "module": "blackjack.db.test_blackjack_data_access",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Run the bot (main.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
